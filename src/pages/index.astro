---
const pageTitle = "Franciscan Community";
const description =
  "A new static website for the Franciscan community, built with Astro and deployed on Cloudflare.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <main>
      <p class="eyebrow">Franciscan Community</p>
      <h1>Peace and good.</h1>
      <p>
        This site is ready for content, navigation, and visual design.
      </p>
    </main>
  </body>
</html>

<style>
  :root {
    color: #1d2521;
    background: #f7f4ed;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  body {
    display: grid;
    min-height: 100vh;
    margin: 0;
    place-items: center;
  }

  main {
    width: min(100% - 2rem, 42rem);
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: #5d6f64;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: #263c30;
    font-size: clamp(2.5rem, 8vw, 5rem);
    line-height: 1;
  }

  p {
    max-width: 34rem;
    margin: 1rem 0 0;
    color: #405249;
    font-size: 1.125rem;
    line-height: 1.7;
  }
</style>

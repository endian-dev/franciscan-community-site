---
const pageTitle = "Page not found | Franciscan Community";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <main>
      <p class="status">404</p>
      <h1>Page not found</h1>
      <p>The page you requested is not available.</p>
      <a href="/">Return home</a>
    </main>
  </body>
</html>

<style>
  :root {
    color: #1d2521;
    background: #f7f4ed;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  body {
    display: grid;
    min-height: 100vh;
    margin: 0;
    place-items: center;
  }

  main {
    width: min(100% - 2rem, 36rem);
  }

  .status {
    margin: 0 0 0.75rem;
    color: #5d6f64;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  h1 {
    margin: 0;
    color: #263c30;
    font-size: clamp(2.25rem, 7vw, 4rem);
    line-height: 1;
  }

  p {
    margin: 1rem 0 0;
    color: #405249;
    font-size: 1.125rem;
    line-height: 1.7;
  }

  a {
    display: inline-block;
    margin-top: 1.5rem;
    color: #7a4b2a;
    font-weight: 700;
  }
</style>

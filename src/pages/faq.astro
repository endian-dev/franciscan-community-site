---
import { getPublishedFaqs, requirePageByRoute } from "@/lib/content";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { render } from "astro:content";

const page = await requirePageByRoute("/faq");
const { Content: PageContent } = await render(page);
const faqEntries = await getPublishedFaqs();
const renderedFaqs = await Promise.all(
  faqEntries.map(async (entry) => ({
    entry,
    Content: (await render(entry)).Content
  }))
);
---

<SiteLayout title={page.data.title} description={page.data.description}>
  <article class="content page-narrow faq-page">
    <h1 class="visually-hidden">{page.data.title}</h1>
    <PageContent />
  </article>

  <section class="faq-list page-narrow" aria-label="Frequently asked questions">
    {
      renderedFaqs.map(({ entry, Content }) => (
        <article class="content faq-entry">
          <h2>Q: {entry.data.question}</h2>
          <Content />
        </article>
      ))
    }
  </section>
</SiteLayout>
